TELEGRAM_ADAPTER_ENABLED=true
BOT_TOKEN=123456789:telegram-token-from-botfather
ALLOWED_USER_IDS=123456789

# Comma-separated absolute paths. The first path is the default repo/workdir.
WORKSPACE_ALLOWLIST=/home/agent

# Optional comma-separated slash command aliases for allowed workspaces.
# Each path must also be present in WORKSPACE_ALLOWLIST.
# Example: /agent switches to /home/agent; /notes switches to /home/agent/MyObsidian.
WORKSPACE_COMMANDS=agent=/home/agent

# Codex execution defaults.
CODEX_BIN=codex
CODEX_MODEL=
CODEX_SANDBOX=workspace-write
CODEX_APPROVAL_POLICY=on-request
CODEX_SKIP_GIT_REPO_CHECK=false

# Optional: pass through selected environment variables to Codex child process.
CODEX_ENV_ALLOWLIST=PATH,HOME,USER,LANG,LC_ALL,TERM,CODEX_HOME

# Telegram behavior.
POLL_TIMEOUT_SECONDS=25
LIVE_UPDATE_INTERVAL_MS=2000
MAX_TELEGRAM_CHARS=3900
JSON_UPLOAD_DIR=/tmp/codex-telegram-upload
MAX_JSON_BYTES=10000000

# Bridge routing.
# The bridge listens to every adapter message but runs Codex only when parsing one of these commands.
BRIDGE_COMMANDS=/codex,@codex,codex:
CODEX_INCLUDE_HISTORY_BY_DEFAULT=false
BRIDGE_MAX_HISTORY_MESSAGES=40

# Optional CollabMD/HTTP adapter.
# POST /v1/messages {"sessionId":"vault-or-page-id","userId":"...","author":"...","text":"/codex task"}
# GET  /v1/sessions/<sessionId>/outbox?after=0
COLLABMD_ADAPTER_ENABLED=false
COLLABMD_BRIDGE_HOST=127.0.0.1
COLLABMD_BRIDGE_PORT=17891
COLLABMD_BRIDGE_TOKEN=
BRIDGE_MAX_HTTP_BODY_BYTES=1000000

# Optional local speech-to-text for Telegram voice/audio messages.
# The bridge appends the converted WAV path as the last argument and expects transcript text on stdout.
STT_COMMAND=scripts/transcribe-faster-whisper
STT_TIMEOUT_MS=120000
MAX_AUDIO_BYTES=20000000
LOCAL_WHISPER_MODEL=Systran/faster-whisper-small
LOCAL_WHISPER_DEVICE=cpu
LOCAL_WHISPER_COMPUTE_TYPE=int8
LOCAL_WHISPER_CPU_THREADS=4
LOCAL_WHISPER_LANGUAGE=ru
LOCAL_WHISPER_LOCAL_FILES_ONLY=true
LOCAL_WHISPER_VAD=true
LOCAL_WHISPER_BEAM_SIZE=3

# Optional alternative: use scripts/transcribe-openai.js instead of local faster-whisper.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TRANSCRIBE_LANGUAGE=ru
OPENAI_TRANSCRIBE_PROMPT=
