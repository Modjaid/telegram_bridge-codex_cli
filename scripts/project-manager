#!/usr/bin/env node
import { existsSync, mkdirSync, readFileSync, renameSync, rmSync, statSync, writeFileSync } from "node:fs";
import path from "node:path";
import { resolveBridgePaths } from "../src/paths.js";

const ROOT = path.resolve(path.dirname(new URL(import.meta.url).pathname), "..");
const ENV_FILE = resolveBridgePaths().configFile;

try {
  main();
} catch (error) {
  console.error(error.message);
  process.exit(1);
}

function main() {
  const [command, ...rest] = process.argv.slice(2);
  const args = parseArgs(rest);
  if (!command || command === "help" || command === "--help") return help();

  const env = readEnvFile(ENV_FILE);
  const projects = csv(getEnv(env, "PROJECT_ALLOWLIST")).map(item => path.resolve(item));
  const commands = buildProjectCommands(getEnv(env, "PROJECT_COMMANDS"), projects);
  const createRoot = path.resolve(args.root || getEnv(env, "PROJECT_CREATE_ROOT") || inferCreateRoot(projects));

  if (command === "list") {
    return print({
      ok: true,
      createRoot,
      projects,
      projectCommands: Object.fromEntries(commands),
    });
  }

  if (command === "create") {
    const inputName = required(args, "name");
    const alias = normalizeProjectName(inputName);
    if (!alias) throw new Error("Project name must contain letters, numbers, underscore, or dash.");
    if (commands.has(alias)) throw new Error(`Project command already exists: /${alias}`);

    const project = path.resolve(createRoot, alias);
    assertInside(createRoot, project);
    if (projects.some(item => path.resolve(item) === project)) {
      throw new Error(`Project is already allowed: ${project}`);
    }

    mkdirSync(project, { recursive: true, mode: 0o700 });
    const agentsPath = path.join(project, "AGENTS.md");
    if (!existsSync(agentsPath)) {
      writeFileSync(agentsPath, defaultAgentsMd(alias), { mode: 0o600 });
    }

    projects.push(project);
    commands.set(alias, project);
    writeProjectEnv(env, projects, commands, createRoot);
    return print({
      ok: true,
      action: "created",
      alias,
      project,
      agentsPath,
      createRoot,
      projects,
      projectCommands: Object.fromEntries(commands),
    });
  }

  if (command === "add") {
    const inputName = required(args, "name");
    const alias = normalizeProjectName(inputName);
    if (!alias) throw new Error("Project name must contain letters, numbers, underscore, or dash.");
    if (commands.has(alias)) throw new Error(`Project command already exists: /${alias}`);

    const project = path.resolve(required(args, "path"));
    if (!existsSync(project) || !statSync(project).isDirectory()) {
      throw new Error(`Existing project directory not found: ${project}`);
    }
    if (projects.some(item => path.resolve(item) === project)) {
      throw new Error(`Project is already allowed: ${project}`);
    }

    const agentsPath = path.join(project, "AGENTS.md");
    if (!existsSync(agentsPath)) {
      writeFileSync(agentsPath, defaultAgentsMd(alias), { mode: 0o600 });
    }

    projects.push(project);
    commands.set(alias, project);
    writeProjectEnv(env, projects, commands, createRoot);
    return print({
      ok: true,
      action: "added",
      alias,
      project,
      agentsPath,
      createRoot,
      projects,
      projectCommands: Object.fromEntries(commands),
    });
  }

  if (command === "delete") {
    const alias = normalizeProjectName(required(args, "name"));
    if (!alias) throw new Error("Project name must contain letters, numbers, underscore, or dash.");
    const project = commands.get(alias);
    if (!project) throw new Error(`Project command not found: /${alias}`);
    assertInside(createRoot, project);

    for (const [commandAlias, commandProject] of commands.entries()) {
      if (path.resolve(commandProject) === path.resolve(project)) commands.delete(commandAlias);
    }
    const remainingProjects = projects.filter(item => path.resolve(item) !== path.resolve(project));
    if (remainingProjects.length === 0) throw new Error("Cannot delete the last allowed project.");
    rmSync(project, { recursive: true, force: true });
    writeProjectEnv(env, remainingProjects, commands, createRoot);
    return print({
      ok: true,
      action: "deleted",
      alias,
      project,
      removedFromAllowlist: remainingProjects.length !== projects.length,
      folderRemoved: true,
      createRoot,
      projects: remainingProjects,
      projectCommands: Object.fromEntries(commands),
    });
  }

  throw new Error(`Unknown command: ${command}`);
}

function parseArgs(argv) {
  const args = {};
  for (let index = 0; index < argv.length; index += 1) {
    const token = argv[index];
    if (!token.startsWith("--")) throw new Error(`Unexpected argument: ${token}`);
    const key = token.slice(2);
    const value = argv[index + 1];
    if (value === undefined) throw new Error(`Missing value for --${key}`);
    args[key] = value;
    index += 1;
  }
  return args;
}

function readEnvFile(file) {
  if (!existsSync(file)) throw new Error(`Missing .env file: ${file}`);
  return readFileSync(file, "utf8").split(/\r?\n/);
}

function getEnv(lines, key) {
  for (const rawLine of lines) {
    const match = rawLine.match(/^([A-Za-z_][A-Za-z0-9_]*)=(.*)$/);
    if (match?.[1] === key) return unquote(match[2]);
  }
  return "";
}

function writeProjectEnv(lines, projects, commands, createRoot) {
  const values = {
    PROJECT_ALLOWLIST: unique(projects.map(item => path.resolve(item))).join(","),
    PROJECT_COMMANDS: [...commands.entries()].map(([alias, project]) => `${alias}=${path.resolve(project)}`).join(","),
    PROJECT_CREATE_ROOT: path.resolve(createRoot),
  };

  const seen = new Set();
  const next = lines.map(line => {
    const match = line.match(/^([A-Za-z_][A-Za-z0-9_]*)=/);
    const key = match?.[1] || "";
    if (!Object.hasOwn(values, key)) return line;
    seen.add(key);
    return `${key}=${values[key]}`;
  });
  for (const [key, value] of Object.entries(values)) {
    if (!seen.has(key)) next.push(`${key}=${value}`);
  }

  const data = `${next.join("\n").replace(/\n*$/, "")}\n`;
  const temp = `${ENV_FILE}.${process.pid}.tmp`;
  writeFileSync(temp, data, { mode: 0o600 });
  renameSync(temp, ENV_FILE);
}

function buildProjectCommands(spec, projects) {
  const commands = new Map();
  for (const project of projects) {
    addProjectAlias(commands, path.basename(project), project);
  }
  if (projects.includes("/home/agent")) addProjectAlias(commands, "agent", "/home/agent");

  for (const item of csv(spec)) {
    const match = item.match(/^\/?([A-Za-z0-9_]+)=(.+)$/);
    if (!match) throw new Error(`Invalid PROJECT_COMMANDS entry: ${item}`);
    addProjectAlias(commands, match[1], path.resolve(match[2].trim()));
  }
  return commands;
}

function addProjectAlias(commands, alias, project) {
  const normalized = String(alias || "").trim().toLowerCase();
  if (!normalized || !/^[a-z0-9_]+$/.test(normalized)) return;
  commands.set(normalized, path.resolve(project));
}

function normalizeProjectName(value) {
  const normalized = String(value || "").trim().toLowerCase().replace(/[\s-]+/g, "_");
  return /^[a-z0-9_]+$/.test(normalized) ? normalized : "";
}

function inferCreateRoot(projects) {
  if (!projects.length) return process.cwd();
  const first = path.resolve(projects[0]);
  if (process.env.HOME && first === path.resolve(process.env.HOME)) return first;
  return path.dirname(first);
}

function assertInside(root, target) {
  const relative = path.relative(root, target);
  if (!relative || relative.startsWith("..") || path.isAbsolute(relative)) {
    throw new Error(`Project path must be inside create root: ${root}`);
  }
}

function defaultAgentsMd(alias) {
  return [
    `# AGENTS.md instructions for /${alias}`,
    "",
    "This project was created by the Codex Telegram Bridge.",
    "",
    "## Notes",
    "",
    "- Keep project-specific instructions here.",
    "- Update this file when project behavior or conventions change.",
    "",
  ].join("\n");
}

function csv(value = "") {
  return String(value).split(",").map(item => item.trim()).filter(Boolean);
}

function unique(items) {
  return [...new Set(items)];
}

function unquote(value) {
  return String(value || "").replace(/^["']|["']$/g, "");
}

function required(args, key) {
  const value = args[key];
  if (value === undefined || value === "") throw new Error(`--${key} is required`);
  return value;
}

function print(value) {
  console.log(JSON.stringify(value, null, 2));
}

function help() {
  console.log(`Usage:
  project-manager list
  project-manager create --name <projectName> [--root <parentPath>]
  project-manager add --name <projectAlias> --path <existingFolder>
  project-manager delete --name <projectName> [--root <parentPath>]`);
}
